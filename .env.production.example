# Web app, set in Vercel.
NEXT_PUBLIC_APP_NAME=KinSvarmo
NEXT_PUBLIC_API_URL=https://api.your-domain.example
NEXT_PUBLIC_CHAIN_ID=16602
NEXT_PUBLIC_INFT_REGISTRY_ADDRESS=0xYourRegistry

# API, set in Railway/Render/Fly/VPS.
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
WEB_ORIGIN=https://your-vercel-app.vercel.app
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.example

# 0G chain, storage, and compute. Keep secrets only on the API host.
ZERO_G_RPC_URL=
ZERO_G_EXPLORER_URL=
ZERO_G_STORAGE_ENDPOINT=
ZERO_G_PRIVATE_KEY=
ZERO_G_INFERENCE_PROVIDER=
ZERO_G_COMPUTE_PROVIDER_ADDRESS=
ZERO_G_COMPUTE_SERVICE_URL=
ZERO_G_COMPUTE_API_SECRET=
ZERO_G_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
ZERO_G_AGENT_REGISTRY_ADDRESS=
ZERO_G_USAGE_AUTHORIZATION_ADDRESS=
OG_COMPUTE_URL=
OG_COMPUTE_API_KEY=
OG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# KeeperHub.
KEEPERHUB_BASE_URL=https://app.keeperhub.com
KEEPERHUB_API_KEY=
KEEPERHUB_WEBHOOK_KEY=
KEEPERHUB_WORKFLOW_ID=
KEEPERHUB_WEBHOOK_RUN_PATH=/api/workflows/:workflowId/webhook
KEEPERHUB_REQUEST_TIMEOUT_MS=10000

# AXL mode for hackathon hosted deployment.
# Leave local mode for the simple one-container API stack.
# Set AXL_TRANSPORT=real and AXL_START_LOCAL_NODES=0 only when separate real AXL nodes are deployed.
AXL_TRANSPORT=local
AXL_START_LOCAL_NODES=1
AXL_START_WORKERS=1
AXL_REQUEST_TIMEOUT_MS=5000
AXL_LOCAL_PORT_OFFSET=0

# Real AXL node URLs if deployed separately.
AXL_NODE_API_URL=
AXL_NODE_API_PEER_ID=
AXL_NODE_PLANNER_URL=
AXL_NODE_PLANNER_PEER_ID=
AXL_NODE_ANALYZER_URL=
AXL_NODE_ANALYZER_PEER_ID=
AXL_NODE_CRITIC_URL=
AXL_NODE_CRITIC_PEER_ID=
AXL_NODE_REPORTER_URL=
AXL_NODE_REPORTER_PEER_ID=

# Persistence.
# TODO: replace in-memory stores with Postgres/Redis before long-lived production use.
DATABASE_URL=
