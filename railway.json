{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.api",
    "watchPatterns": [
      "Dockerfile.api",
      ".dockerignore",
      "apps/api/**",
      "packages/**",
      "scripts/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm deploy:api-stack",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
